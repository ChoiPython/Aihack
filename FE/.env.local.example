GEMINI_API_KEY=
DATABASE_URL=
CHROMA_URL=http://localhost:8000

# 임시: FE/lib/ai(AI/RAG 리드 담당, 아직 미구현)가 준비될 때까지 브라우저에서 Gemini를
# 직접 호출하는 임시 구현(FE/src/services/geminiClient.js)이 쓰는 값. Vite는 VITE_ 접두사가
# 붙은 값만 클라이언트 번들에 넣으므로 키가 노출된다 — lib/ai가 완성되면 이 값과
# geminiClient.js 호출부를 제거하고 서버리스 함수 호출로 옮길 것.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
